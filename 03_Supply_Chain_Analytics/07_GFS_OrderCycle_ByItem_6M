/*******************************************************************************
OBJECT NAME:    GFS_OrderCycle_ByItem_6M
DESCRIPTION:    Macro Item-Level Velocity View. Analyzes rolling 6-month product 
                ordering cycles, aggregate sample sizes, and volume velocity.
                
                * NOTE ON BUSINESS LOGIC LIMITATION *
                The monthly and weekly averages are calculated using a fixed 
                6-month denominator rather than adjusting for each store’s actual 
                operating period. As a result, stores that opened recently may 
                have their averages slightly understated due to the inclusion 
                of inactive months.
AUTHOR:         Sajava Chang
DATE:           2026-07
TYPE:           Supply Chain Demand Planning / Rolling Forecast View
DEPENDENCIES:   y_GFS_OrderGaps, Item, Store, GFSsales
*******************************************************************************/

SELECT
    -- Product Identification
    y_GFS_OrderGaps.ItemCode,
    Item.ItemName,
    
    -- Aggregate Order Gap Analytics (Rolling Window)
    ROUND(AVG(DATEDIFF("m", ThisMonth, NextOrderMonth)), 1) AS AvgGapMonths,
    MAX(DATEDIFF("m", ThisMonth, NextOrderMonth)) AS MaxGapMonths,
    COUNT(*) AS SampleSize,
    
    -- Rolling 6-Month Volumetric Baselines
    NZ(Totals.OrderCount, 0) AS OrderCount,
    NZ(Totals.TotalQty, 0) AS TotalQty,
    
    -- Fixed-Window Velocity Calculations (Macro Baseline)
    ROUND(NZ(Totals.TotalQty, 0) / 6, 2) AS AvgQtyPerMonth,
    ROUND(NZ(Totals.TotalQty, 0) / (6 * 4.33), 2) AS AvgQtyPerWeek

FROM
    (
        (
            y_GFS_OrderGaps
            LEFT JOIN Item 
                ON y_GFS_OrderGaps.ItemCode = Item.ItemCode
        )
        INNER JOIN Store 
            ON y_GFS_OrderGaps.StoreCode = Store.StoreCode
    )
    LEFT JOIN
        (
            SELECT
                G.ItemCode,
                COUNT(*) AS OrderCount,
                SUM(G.Qty) AS TotalQty
            FROM 
                GFSsales AS G
                INNER JOIN Store AS S 
                    ON G.StoreCode = S.StoreCode
            WHERE 
                S.Active IS NOT NULL
                AND G.Month >= DATEADD("m", -5, (SELECT MAX(Month) FROM GFSsales))
            GROUP BY 
                G.ItemCode
        ) AS Totals
            ON y_GFS_OrderGaps.ItemCode = Totals.ItemCode

WHERE
    y_GFS_OrderGaps.NextOrderMonth IS NOT NULL
    AND Store.Active IS NOT NULL
    AND y_GFS_OrderGaps.ThisMonth >= DATEADD("m", -5, (SELECT MAX(Month) FROM GFSsales))

GROUP BY
    y_GFS_OrderGaps.ItemCode, 
    Item.ItemName, 
    Totals.OrderCount, 
    Totals.TotalQty;
